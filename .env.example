# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Auth0 Authentication Configuration
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=your_auth0_client_id
AUTH0_CLIENT_SECRET=your_auth0_client_secret
AUTH0_SECRET=use_a_64_char_hex_string
APP_BASE_URL=http://localhost:3000

# Application Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=GPULaw Attorney Services

# Database Configuration (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/dbname?sslmode=require

# Optional: GPULaw Main Platform Integration
# GPULAW_API_URL=http://localhost:3000
# GPULAW_API_KEY=your_gpulaw_api_key_here
